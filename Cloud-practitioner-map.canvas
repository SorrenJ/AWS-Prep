		{"id":"ae6c05618ecace94","type":"text","text":"Site-to-Site VPN\n\nConnect your on-premise VPN  to a VPC. Allows On-Premise to connect with AWS\n\nencrypted and goes over pbulic internet","x":-1696,"y":3160,"width":464,"height":337,"color":"3"},
